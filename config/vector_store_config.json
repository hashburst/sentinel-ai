{
  "vector_store": {
    "type": "indexeddb",
    "max_vectors": 5000,
    "eviction_policy": "lru",
    "dimension": 384,
    "model": "all-MiniLM-L6-v2",
    "similarity_metric": "cosine"
  },
  "indexing": {
    "batch_size": 100,
    "interval_seconds": 60,
    "fields": ["title", "description", "content"]
  },
  "search": {
    "default_limit": 10,
    "max_limit": 100,
    "min_score": 0.5
  }
}
